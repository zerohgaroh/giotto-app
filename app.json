{
  "expo": {
    "name": "Giotto Staff Mobile",
    "slug": "giotto-staff-mobile",
    "scheme": "giottostaff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand-logo-clean.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand-logo-clean.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand-logo-clean.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "uz.unqm.giottostaff"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/brand-logo-clean.png",
          "color": "#0D2B6B"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/brand-logo-clean.png"
    }
  }
}
